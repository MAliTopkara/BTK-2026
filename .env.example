# Ortam Değişkenleri — TrustLens AI

# Kopyala: cp .env.example .env
# .env dosyasını asla commit'leme!

# ================================
# Google Gemini AI
# ================================
GEMINI_API_KEY=your_gemini_api_key_here

# ================================
# Supabase
# ================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# ================================
# Redis (Upstash)
# ================================
REDIS_URL=rediss://your-upstash-url:6379

# ================================
# App Config
# ================================
ENVIRONMENT=development
# production veya development
FRONTEND_URL=http://localhost:3000
# Production'da: https://btk-2026.vercel.app

# ================================
# Frontend (Next.js public vars)
# ================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
NEXT_PUBLIC_API_URL=http://localhost:8000
# Production'da: https://your-railway-app.railway.app

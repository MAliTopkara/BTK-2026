{
  "manifest_version": 3,
  "name": "TrustLens AI",
  "version": "1.0.0",
  "description": "E-ticaret ürün sayfalarında güven skoru — 7 katmanlı AI analizi",
  "permissions": ["activeTab", "storage"],
  "host_permissions": [
    "https://www.trendyol.com/*",
    "https://www.hepsiburada.com/*",
    "https://www.n11.com/*"
  ],
  "action": {
    "default_popup": "src/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.trendyol.com/*-p-*",
        "https://www.hepsiburada.com/*-p-*",
        "https://www.n11.com/urun/*"
      ],
      "js": ["src/content.js"],
      "css": ["src/content.css"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
